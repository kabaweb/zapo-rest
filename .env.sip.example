# ──────────────────────────────────────────────────────────────────────────────
# .env para testes da integração SIP trunk (desenvolvimento local).
#
# Cenário 1 — Com Asterisk no Docker (docker-compose.sip.yml):
#   Copie este arquivo para .env e rode:
#     docker compose -f docker-compose.yml -f docker-compose.sip.yml up -d
#
# Cenário 2 — Com FreePBX externo (host mode / bare metal):
#   Ajuste SIP_PROXY_HOST para o IP do FreePBX.
#   No FreePBX, crie:
#     - Extensão PJSIP: username=zapo, password=zapo123
#     - DID routes para os números mapeados no SIP_DID_MAPPING
#
# Cenário 3 — Sem Asterisk (apenas zapo-rest + Postgres + Redis):
#   Deixe SIP_TRUNK_ENABLED=false. A API funciona normalmente sem SIP.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# Admin key — full access (min 16 chars)
ADMIN_API_KEY=change-me-admin-key-32chars!!

DATABASE_URL=postgresql://zapo:zapo@localhost:5555/zapo
REDIS_URL=redis://localhost:16379

AUTO_CONNECT_ON_BOOT=true
RECONNECT_MAX_ATTEMPTS=10
WEBHOOK_TIMEOUT_MS=5000
VOIP_MAX_CONCURRENT_CALLS=10
VOIP_END_CALL_ON_WS_CLOSE=false
MEDIA_TMP_DIR=/tmp/zapo-rest-media
HISTORY_SYNC_ENABLED=true
MEDIA_AUTO_DOWNLOAD=true
WAM_ENABLED=true

# ── Media storage (local para dev) ────────────────────────────────────────────
MEDIA_STORAGE=local
MEDIA_LOCAL_DIR=/tmp/zapo-rest-media/objects
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/v1/media

# ── SIP Trunk ────────────────────────────────────────────────────────────────
SIP_TRUNK_ENABLED=true
SIP_TRANSPORT=udp

# IP da máquina rodando o zapo-rest (NÃO use 127.0.0.1 se o Asterisk estiver
# em outro container — use o IP da interface de rede real).
SIP_LOCAL_HOST=0.0.0.0
SIP_LOCAL_PORT=5070

# Host do Asterisk / FreePBX / provedor SIP
# - Docker compose: asterisk (nome do serviço)
# - FreePBX externo:  IP do host
# - Provedor SIP:     sip.provedor.com
SIP_PROXY_HOST=127.0.0.1
SIP_PROXY_PORT=5060

# Credenciais SIP (devem bater com o configurado no Asterisk/FreePBX)
SIP_USERNAME=zapo
SIP_PASSWORD=zapo123
SIP_DISPLAY_NAME=Zapo SIP
SIP_REALM=asterisk

# Codec: alaw (Brasil/mundo) | ulaw (EUA/Japão)
SIP_CODEC=alaw

# Intervalo de re-registro (segundos). O re-registro ocorre na metade.
SIP_REGISTER_EXPIRY_SECS=3600

# Mapeamento DID → número WhatsApp.
# Quando um INVITE chega para sip:1001@realm, o zapo-rest origina uma chamada
# WhatsApp para 5511999999999.
# Formato: "DID1=phone1,DID2=phone2"
SIP_DID_MAPPING=1001=5511999999999

# Fallback: número WhatsApp padrão quando o DID não tem mapeamento explícito.
SIP_DEFAULT_DST_DID=5511999999999

# ── Speech-to-text (opcional) ─────────────────────────────────────────────────
STT_ENABLED=false
